{
  "name": "domo-publish-action",
  "version": "4.0.0",
  "description": "GitHub Action for deploying Domo apps to Domo instances",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist",
    "test": "jest",
    "lint": "eslint src/**/*.js",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "keywords": [
    "github-action",
    "domo",
    "deployment",
    "domo-cli"
  ],
  "author": "Domo Developer Innovations",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@actions/io": "^1.1.2",
    "ryuu": "^5.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.0",
    "eslint": "^8.55.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.3",
    "prettier": "^3.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
